{
  "name": "openapi-agent-reference",
  "version": "2.0.0",
  "description": "Generate agent-friendly Markdown API reference documentation from OpenAPI JSON.",
  "type": "commonjs",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "openapi-md": "bin/openapi-md.js"
  },
  "scripts": {
    "generate": "node bin/openapi-md.js generate openapi.json -o API_REFERENCE.md",
    "groups": "node bin/openapi-md.js groups openapi.json",
    "test": "node --test",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dikong1/extractOpenApi.git"
  },
  "homepage": "https://github.com/Dikong1/extractOpenApi#readme",
  "bugs": {
    "url": "https://github.com/Dikong1/extractOpenApi/issues"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "openapi",
    "swagger",
    "markdown",
    "api-documentation",
    "ai-agent",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  }
}
